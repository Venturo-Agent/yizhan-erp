# Venturo 環境變數設定檔範本
# 複製此檔案為 .env.local 並填入實際的值

# ============================================
# 安全性設定（Production 必填）
# ============================================
# JWT Secret - 用於驗證登入 token（至少 32 字元的隨機字串）
JWT_SECRET=
# Quick Login Secret - 用於快速登入功能（client + middleware 共用）
NEXT_PUBLIC_QUICK_LOGIN_SECRET=

# ============================================
# 應用配置
# ============================================
NEXT_PUBLIC_APP_NAME=Venturo ERP
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# 公司名稱（用於合約 / 列印 / 公開頁、可選、不填走 lib/tenant.ts 的預設）
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_COMPANY_NAME_EN=

# ============================================
# 功能開關
# ============================================
# 啟用除錯模式
NEXT_PUBLIC_DEBUG_MODE=false

# ============================================
# 開發環境設定
# ============================================
# 開發伺服器 Port（跟 package.json scripts 對齊）
PORT=3000

# 是否啟用 React DevTools
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
# Sentry 錯誤追蹤 (可選)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# Unsplash API (免費圖庫搜尋)
# ============================================
# 前往 https://unsplash.com/developers 申請 Access Key
# ⚠️ server-only — 不要加 NEXT_PUBLIC_ 前綴（key 不應暴露給瀏覽器）
# 所有搜尋請求走 /api/unsplash/search 代理
UNSPLASH_ACCESS_KEY=

# ============================================
# Platform integrations（Super App 戰略外部 SaaS）
# ============================================
# AiToEarn iframe 整合 URL（/platform/aitoearn 讀）
# 預設走 production 部署、要連別的 instance 才覆蓋
NEXT_PUBLIC_AITOEARN_URL=https://aitoearn.venturo.tw

# ============================================
# Supabase 設定
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# CLI 用（非 runtime）
# SUPABASE_ACCESS_TOKEN=

# ============================================
# OCR / Vision / AI 設定
# ============================================
GOOGLE_VISION_API_KEY=
# 多 key（逗號分隔）
GOOGLE_VISION_API_KEYS=
OCR_SPACE_API_KEY=
# CIS 智能分析（可選、有設才走 LLM、否則走 heuristic）
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# LINE Bot LLM（可選、沒設則 bot 走規則 fallback、demo 仍會跑）
# OpenRouter API key、預設 model = deepseek/deepseek-v3
OPENROUTER_API_KEY=
# 多通路 AI brain（M8、FB / IG / LINE 共用）— Anthropic Claude Sonnet 4.6
# 沒設則 webhook 收到訊息只存 DB、不自動回覆（fallback 給 agent 接手）
# 跟 ANTHROPIC_API_KEY 共用一支 key 也行、就不重複設
VENTURO_AI_BRAIN_KEY=
VENTURO_AI_BRAIN_MODEL=claude-sonnet-4-6

# ============================================
# Google Maps API 設定
# ============================================
# 用於景點座標自動取得（Places API）
# 申請網址：https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# 外部 API
# ============================================
# 航班資料
AERODATABOX_API_KEY=
NEXT_PUBLIC_RAPIDAPI_KEY=
# Amadeus TOTP（驗證碼加密 key、給訂位系統用）
AMADEUS_TOTP_ENCRYPTION_KEY=
# 第三方整合敏感欄位加密（API key / access token / channel secret 等）
# 用途：encrypt workspace_integrations + 各通路 setup token、AES-256-GCM
# 產生：openssl rand -base64 32
# ⚠️ production / staging 部署必設、不設則 setup wizard 寫 token 會 throw
VENTURO_INTEGRATION_ENCRYPTION_KEY=
# 個人敏感欄位加密（身分證字號 / 銀行帳號、SEC-012）
# 用途：employees.encrypted_bank_account_number + employees.encrypted_id_number、AES-256-GCM
# 產生：openssl rand -base64 32
# ⚠️ server-side only — 不加 NEXT_PUBLIC_ 前綴（key 永不暴露給瀏覽器）
# ⚠️ production / staging 部署必設、不設則 PATCH /api/employees/[id] 寫銀行帳號會 throw 500
# ⚠️ 跟 VENTURO_INTEGRATION_ENCRYPTION_KEY 分開管理（隔離洩漏範圍）
PERSONAL_DATA_ENCRYPTION_KEY=
# 圖庫
# ⚠️ server-only — 不要加 NEXT_PUBLIC_ 前綴（key 不應暴露給瀏覽器）
# 所有搜尋請求走 /api/pexels/search 代理
PEXELS_API_KEY=
# 代理（可選）
# QUOTAGUARD_STATIC_URL=

# ============================================
# Venturo Online 連結
# ============================================
NEXT_PUBLIC_ONLINE_URL=http://localhost:3001

# ============================================
# Bot / Cron 安全
# ============================================
BOT_API_SECRET=
CRON_SECRET=

# ============================================
# FastMove API（可選）
# ============================================
# NEXT_PUBLIC_FASTMOVE_API_URL=
# NEXT_PUBLIC_FASTMOVE_API_KEY=

# ============================================
# 日誌設定
# ============================================
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_REMOTE_LOGGING=false
NEXT_PUBLIC_ENABLE_SUPABASE=true
