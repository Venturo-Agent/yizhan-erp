# ====================================================================
# 本機開發 env 範本（2026-05-23 Sprint A William 拍板）
#
# 用法：
#   1. cp .env.development.local.example .env.development.local
#   2. 跑 `supabase start`、複製輸出的 anon/service_role key 填這檔
#   3. 跑 `npm run seed:local` 灌假資料
#   4. 跑 `npm run dev`、走 http://localhost:3000
#
# 為什麼分開：
#   - .env.local 用 production Supabase、改 schema 怕死客戶資料
#   - .env.development.local 用本機 docker supabase、隨便 reset 不影響任何人
#   - Next.js auto-load order：.env.development.local > .env.local > .env
# ====================================================================

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Venturo ERP (本機開發)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Supabase（本機 docker、跑 supabase start 後填）
# ============================================
# 跑 `supabase start` 會印一段：
#         API URL: http://127.0.0.1:54321
#     GraphQL URL: http://127.0.0.1:54321/graphql/v1
#          DB URL: postgresql://postgres:postgres@127.0.0.1:54322/postgres
#      Studio URL: http://127.0.0.1:54323
#        anon key: eyJhbGciOi...（127 字元 JWT）
# service_role key: eyJhbGciOi...（同上）
# 把上面兩個 key 填到下面
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 永豐金流（本機開發走 mock）
# ============================================
# SINOPAC_ENV: mock | uat | production
# - mock     = 完全假連結、不打永豐 API（本機 / Phase 1 demo）
# - uat      = 接 eposuat.sinopac.com（拿到測試特店號後）
# - production = 接 epos.sinopac.com（正式合約後）
SINOPAC_ENV=mock

# UAT 特店號（拿到合約後填、本機不需要）
# SINOPAC_UAT_SHOP_NO=
# SINOPAC_UAT_HASH_ID=
# SINOPAC_UAT_X_KEY_ID=
# SINOPAC_UAT_API_URL=https://eposuat.sinopac.com

# ============================================
# 加密 keys（本機隨便產一個就好、不能用 production 那把）
# ============================================
# 產生：openssl rand -base64 32
VENTURO_INTEGRATION_ENCRYPTION_KEY=
PERSONAL_DATA_ENCRYPTION_KEY=
AMADEUS_TOTP_ENCRYPTION_KEY=
JWT_SECRET=
NEXT_PUBLIC_QUICK_LOGIN_SECRET=

# ============================================
# 第三方 API（本機開發大多可空、用到時再填）
# ============================================
# 留空走 mock / 跳過、不會 break
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_API_KEYS=
OCR_SPACE_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
VENTURO_AI_BRAIN_KEY=
VENTURO_AI_BRAIN_MODEL=claude-sonnet-4-6
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
MINIMAX_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ============================================
# Bot / Cron / 內部 API（本機隨便）
# ============================================
BOT_API_SECRET=local-dev-not-secret
CRON_SECRET=local-dev-not-secret

# ============================================
# Log / Debug
# ============================================
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_REMOTE_LOGGING=false
NEXT_PUBLIC_ENABLE_SUPABASE=true
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
